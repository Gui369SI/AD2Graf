@model AD2Graf.Models.Servico

@{
    ViewData["Title"] = "Excluir Serviço";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Excluir Serviço</h2>
            <p style="color: #999; font-size: 0.95rem;">Você tem certeza que deseja excluir?</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px;">
            <div style="margin-bottom: 32px;">
                <h3 style="color: #1a1a1a; font-weight: 600; margin-bottom: 16px;">@Model.Nome</h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Preço do Serviço</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 1rem;">R$ @Model.PrecoServico.ToString("N2")</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Data de Cadastro</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 1rem;">@Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div style="background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 12px 16px; border-radius: 4px; margin-bottom: 24px;">
                    <p style="color: #856404; font-size: 0.9rem; margin: 0;">
                        <i class="bi bi-exclamation-triangle-fill"></i> Esta ação não pode ser desfeita.
                    </p>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #dc3545; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer;">
                        Sim, Excluir
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
