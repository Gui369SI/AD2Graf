@model AD2Graf.Models.Pedido

@{
    ViewData["Title"] = "Excluir Pedido";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Excluir Solicitação</h2>
            <p style="color: #999; font-size: 0.95rem;">Tem certeza que deseja remover este pedido?</p>
        </div>

        <div style="border: 2px solid #dc3545; border-radius: 4px; padding: 40px; background-color: #fff5f5;">
            <div style="margin-bottom: 32px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Empresa</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Empresa</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Descrição</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Descricao</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Quantidade</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Quantidade</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Preço</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Preco.ToString("C")</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Status</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Html.DisplayFor(m => m.Status)</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Data</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div style="border-top: 1px solid #e8e8e8; padding-top: 24px;">
                    <p style="color: #dc3545; font-weight: 600; margin-bottom: 8px;">
                        <i class="bi bi-exclamation-circle-fill" style="margin-right: 8px;"></i>
                        Esta ação não pode ser desfeita!
                    </p>
                    <p style="color: #999; font-size: 0.9rem;">
                        O pedido será permanentemente removido do sistema.
                    </p>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #dc3545; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.3s;">
                        <i class="bi bi-trash-fill" style="margin-right: 8px;"></i>
                        Confirmar Exclusão
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center; transition: all 0.3s;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>