@model AD2Graf.Models.Pedido

@{
    ViewData["Title"] = "Excluir Pedido";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Excluir Pedido</h2>
            <p style="color: #999; font-size: 0.95rem;">Tem certeza que deseja remover este pedido?</p>
        </div>

        <div style="border: 2px solid #dc3545; border-radius: 4px; padding: 40px; background-color: #fff5f5;">
            <div style="margin-bottom: 32px;">
                <h3 style="color: #1a1a1a; font-weight: 600; margin-bottom: 24px;">@Model.Empresa</h3>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Serviço</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 1rem;">@Model.Servico?.Nome</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Status</p>
                        <span style="display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600;
                            background-color: @(Model.Status == AD2Graf.Models.StatusPedido.Pendente ? "#fff3cd" :
                                                                                    Model.Status == AD2Graf.Models.StatusPedido.EmAndamento ? "#cfe2ff" :
                                                                                    Model.Status == AD2Graf.Models.StatusPedido.Concluido ? "#d4edda" : "#f8d7da");
                            color: @(Model.Status == AD2Graf.Models.StatusPedido.Pendente ? "#997404" :
                                                                         Model.Status == AD2Graf.Models.StatusPedido.EmAndamento ? "#084298" :
                                                                         Model.Status == AD2Graf.Models.StatusPedido.Concluido ? "#155724" : "#721c24");">
                            @Model.Status
                        </span>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Quantidade</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 1rem;">@Model.Quantidade</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Data de Cadastro</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 1rem;">@Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div style="background-color: #f8d7da; border-left: 4px solid #dc3545; padding: 12px 16px; border-radius: 4px; margin-bottom: 24px;">
                    <p style="color: #721c24; font-size: 0.9rem; margin: 0; font-weight: 600;">
                        <i class="bi bi-exclamation-circle-fill"></i> Esta ação não pode ser desfeita!
                    </p>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #dc3545; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <i class="bi bi-trash-fill"></i> Confirmar Exclusão
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
