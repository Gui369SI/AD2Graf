@model AD2Graf.Models.Pedido

@{
    ViewData["Title"] = "Novo Pedido";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Nova Solicitação</h2>
            <p style="color: #999; font-size: 0.95rem;">Preencha os dados do pedido de impressão</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px;">
            <form asp-action="Create" method="post">
                <div style="margin-bottom: 24px;">
                    <label asp-for="Empresa" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Empresa / Organização</label>
                    <input asp-for="Empresa" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;"/>
                    <span asp-validation-for="Empresa" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Descricao" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Descrição</label>
                    <input asp-for="Descricao" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" placeholder="Ex: Flyer, Banner, Panfleto..." />
                    <span asp-validation-for="Descricao" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Quantidade" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Quantidade</label>
                    <input asp-for="Quantidade" type="number" min="1" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;"/>
                    <span asp-validation-for="Quantidade" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Preco" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Preço Unit.</label>
                    <div style="display: flex; gap: 0;">
                        <span style="padding: 12px 16px; background-color: #3d3d3d; color: white; font-weight: 500;">R$</span>
                        <input asp-for="Preco" type="number" step="0.01" min="0.01" style="flex: 1; padding: 12px 16px; border: 1px solid #e8e8e8; border-left: none; border-radius: 0 4px 4px 0; font-size: 0.95rem; font-family: inherit;" placeholder="0,00" />
                    </div>
                    <span asp-validation-for="Preco" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 32px;">
                    <label asp-for="Status" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Status</label>
                    <select asp-for="Status" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;"
                            asp-items="Html.GetEnumSelectList<AD2Graf.Models.StatusPedido>()">
                    </select>
                </div>

                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #3d3d3d; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.3s;">
                        Salvar Pedido
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center; transition: all 0.3s;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}