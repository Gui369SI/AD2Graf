@model AD2Graf.Models.Pedido

@{
    ViewData["Title"] = "Nova Solicitação";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Novo Pedido</h2>
            <p style="color: #999; font-size: 0.95rem;">Preencha os dados do pedido de impressão</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px;">
            <form asp-action="Create" method="post" novalidate>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Empresa" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Empresa / Organização</label>
                    <input asp-for="Empresa" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" />
                    <span asp-validation-for="Empresa" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="ServicoId" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Serviço</label>
                    <select asp-for="ServicoId" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;">
                        <option value="">-- Selecione um Serviço --</option>
                        @if (ViewBag.Servicos != null)
                        {
                            @foreach (var servico in ViewBag.Servicos)
                            {
                                <option value="@servico.Id">@servico.Nome - R$ @servico.PrecoServico.ToString("N2")</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="ServicoId" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Quantidade" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Quantidade</label>
                    <input asp-for="Quantidade" type="number" min="1" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" />
                    <span asp-validation-for="Quantidade" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #3d3d3d; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer;">
                        Salvar Pedido
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
