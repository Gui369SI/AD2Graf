@model AD2Graf.Models.Movimentacao

@{
    ViewData["Title"] = "Excluir Movimentação";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Excluir Movimentação</h2>
            <p style="color: #999; font-size: 0.95rem;">Tem certeza que deseja remover esta movimentação?</p>
        </div>

        @if (TempData["Erro"] != null)
        {
            <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px; padding: 16px; margin-bottom: 24px; color: #721c24;">
                <i class="bi bi-exclamation-circle-fill" style="margin-right: 8px;"></i>
                @TempData["Erro"]
            </div>
        }

        <div style="border: 2px solid #dc3545; border-radius: 4px; padding: 40px; background-color: #fff5f5;">
            <div style="margin-bottom: 32px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Insumo</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Insumo?.Nome</p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Tipo</p>
                        @{
                            bool isEntrada = Model.TipoMovimentacao == AD2Graf.Models.TipoMovimentacao.Entrada;
                        }
                        <span style="display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 4px; font-size: 0.85rem; font-weight: 600;
                            background-color: @(isEntrada ? "#d4edda" : "#f8d7da");
                            color: @(isEntrada ? "#155724" : "#721c24");">
                            <i class="bi @(isEntrada ? "bi-arrow-down-circle-fill" : "bi-arrow-up-circle-fill")"></i>
                            @(isEntrada ? "Entrada" : "Saída")
                        </span>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Quantidade</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">
                            @(isEntrada ? "+" : "-")@Model.Quantidade.ToString("N2")
                        </p>
                    </div>
                    <div>
                        <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Data de Registro</p>
                        <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.DataMovimentacao.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div style="border-top: 1px solid #e8e8e8; padding-top: 24px;">
                    <p style="color: #dc3545; font-weight: 600; margin-bottom: 8px;">
                        <i class="bi bi-exclamation-circle-fill" style="margin-right: 8px;"></i>
                        Esta ação não pode ser desfeita!
                    </p>
                    <p style="color: #999; font-size: 0.9rem;">
                        A movimentação será removida e o saldo do estoque será revertido automaticamente.
                    </p>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #dc3545; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer;">
                        <i class="bi bi-trash-fill" style="margin-right: 8px;"></i>
                        Confirmar Exclusão
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
