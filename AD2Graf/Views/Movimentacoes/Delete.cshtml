@model AD2Graf.Models.Movimentacao

@{
    ViewData["Title"] = "Excluir";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Excluir</h1>

<h3>Tem certeza que deseja excluir esta movimentação?</h3>
<div>
    <h4>Movimentacao</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Tipo de Insumo
        </dt>
        <dd class="col-sm-10">
            @Model.Insumo?.Nome
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TipoMovimentacao)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TipoMovimentacao)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Quantidade)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Quantidade)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DataMovimentacao)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DataMovimentacao)
        </dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="submit" value="Confirmar Exclusão" class="btn btn-danger" /> |
        <a asp-action="Index">Voltar</a>
    </form>
</div>
