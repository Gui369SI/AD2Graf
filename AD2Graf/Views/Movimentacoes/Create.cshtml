@model AD2Graf.Models.Movimentacao

@{
    ViewData["Title"] = "Registrar Movimentação";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Registrar Movimentação</h2>
            <p style="color: #999; font-size: 0.95rem;">Registre uma entrada ou saída de material</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px;">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" style="color: #dc3545; margin-bottom: 16px;"></div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="InsumoId" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Tipo de Insumo</label>
                    <select asp-for="InsumoId" asp-items="ViewBag.InsumoId" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;">
                        <option value="">-- Selecione --</option>
                    </select>
                    <span asp-validation-for="InsumoId" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="TipoMovimentacao" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Entrada / Saída</label>
                    <select asp-for="TipoMovimentacao" asp-items="Html.GetEnumSelectList<AD2Graf.Models.TipoMovimentacao>()" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;">
                        <option value="">-- Selecione --</option>
                    </select>
                    <span asp-validation-for="TipoMovimentacao" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 24px;">
                    <label asp-for="Quantidade" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Quantidade</label>
                    <input asp-for="Quantidade" type="number" min="1" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" />
                    <span asp-validation-for="Quantidade" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="margin-bottom: 32px;">
                    <label asp-for="DataMovimentacao" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Data da Movimentação</label>
                    <input asp-for="DataMovimentacao" type="datetime-local" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" />
                    <span asp-validation-for="DataMovimentacao" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #3d3d3d; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer;">
                        Registrar
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                        Voltar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}