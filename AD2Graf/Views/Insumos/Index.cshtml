@model IEnumerable<AD2Graf.Models.Insumo>

@{
    ViewData["Title"] = "Gestão de Insumos";
}

<div class="container" style="padding: 60px 0;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
        <div>
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Gestão de Insumos</h2>
            <p style="color: #999; font-size: 0.95rem;">Cadastre e gerencie os materiais disponíveis</p>
        </div>
        <a asp-action="Create" style="background-color: #3d3d3d; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; font-weight: 500; display: flex; align-items: center; gap: 8px; transition: all 0.3s;">
            <i class="bi bi-plus-circle-fill"></i> Novo Insumo
        </a>
    </div>

    <div style="overflow-x: auto; border: 2px solid #3d3d3d; border-radius: 4px;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background-color: #f5f3f0; border-bottom: 2px solid #3d3d3d;">
                    <th style="padding: 16px; text-align: left; color: #1a1a1a; font-weight: 600; font-size: 0.9rem;">Nome do Insumo</th>
                    <th style="padding: 16px; text-align: left; color: #1a1a1a; font-weight: 600; font-size: 0.9rem;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr style="border-bottom: 1px solid #e8e8e8;">
                        <td style="padding: 16px; color: #333;">@item.Nome</td>
                        <td style="padding: 16px;">
                            <div style="display: flex; gap: 8px;">
                                <a asp-action="Edit" asp-route-id="@item.Id" style="padding: 6px 12px; background-color: transparent; color: #3d3d3d; border: 1px solid #3d3d3d; border-radius: 4px; text-decoration: none; font-size: 0.85rem; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                                    <i class="bi bi-pencil-fill"></i> Editar
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" style="padding: 6px 12px; background-color: transparent; color: #dc3545; border: 1px solid #dc3545; border-radius: 4px; text-decoration: none; font-size: 0.85rem; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                                    <i class="bi bi-trash-fill"></i> Excluir
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 60px 20px; color: #999;">
            <i class="bi bi-bag" style="font-size: 3rem; display: block; margin-bottom: 16px;"></i>
            <p style="font-size: 1.1rem;">Nenhum insumo cadastrado ainda</p>
            <p style="margin-top: 8px;">
                <a asp-action="Create" style="color: #3d3d3d; font-weight: 500; text-decoration: none;">Adicionar primeiro insumo →</a>
            </p>
        </div>
    }
</div>

<style>
    tr:hover {
        background-color: #f9f9f9;
    }

    a:hover {
        opacity: 0.8;
    }
</style>