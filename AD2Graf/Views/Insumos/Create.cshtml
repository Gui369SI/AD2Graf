@model AD2Graf.Models.Insumo

@{
    ViewData["Title"] = "Novo Insumo";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Novo Insumo</h2>
            <p style="color: #999; font-size: 0.95rem;">Cadastre um novo material para o estoque</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px;">
            <form asp-action="Create" method="post">
                <div style="margin-bottom: 32px;">
                    <label asp-for="Nome" style="display: block; color: #1a1a1a; font-weight: 600; margin-bottom: 8px; font-size: 0.95rem;">Nome do Insumo</label>
                    <input asp-for="Nome" style="width: 100%; padding: 12px 16px; border: 1px solid #e8e8e8; border-radius: 4px; font-size: 0.95rem; font-family: inherit;" />
                    <span asp-validation-for="Nome" style="display: block; color: #dc3545; font-size: 0.85rem; margin-top: 4px;"></span>
                </div>

                <div style="display: flex; gap: 12px;">
                    <button type="submit" style="flex: 1; padding: 12px 24px; background-color: #3d3d3d; color: white; border: none; border-radius: 4px; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.3s;">
                        Salvar Insumo
                    </button>
                    <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: transparent; color: #3d3d3d; border: 2px solid #3d3d3d; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center; transition: all 0.3s;">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}