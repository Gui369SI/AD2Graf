@model AD2Graf.Models.Estoque

@{
    ViewData["Title"] = "Detalhes do Material";
}

<div class="container" style="padding: 60px 0;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div style="margin-bottom: 40px;">
            <h2 style="color: #1a1a1a; font-weight: 700; font-size: 2rem; margin-bottom: 8px;">Detalhes do Material</h2>
            <p style="color: #999; font-size: 0.95rem;">Informações completas do registro em estoque</p>
        </div>

        <div style="border: 2px solid #3d3d3d; border-radius: 4px; padding: 40px; background-color: #fafafa;">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
                <div>
                    <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Material</p>
                    <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.Insumo?.Nome</p>
                </div>
                <div>
                    <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Quantidade em Estoque</p>
                    <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.QuantidadeEstoque</p>
                </div>
                <div>
                    <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Preço Unit.</p>
                    <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.PrecoUnitario.ToString("C")</p>
                </div>
                <div>
                    <p style="color: #999; font-size: 0.85rem; margin-bottom: 4px;">Data de Cadastro</p>
                    <p style="color: #1a1a1a; font-weight: 600; font-size: 0.95rem;">@Model.DataCadastro.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            <div style="border-top: 1px solid #e8e8e8; padding-top: 24px; display: flex; gap: 12px;">
                <a asp-action="Index" style="flex: 1; padding: 12px 24px; background-color: #3d3d3d; color: white; border-radius: 4px; font-weight: 600; font-size: 0.95rem; text-decoration: none; text-align: center;">
                    <i class="bi bi-arrow-left" style="margin-right: 8px;"></i> Voltar
                </a>
            </div>
        </div>
    </div>
</div>
